# Copy to .env and fill the values you actually want to use.

# Required only when --caption-provider glm is enabled.
GLM_API_KEY=

# SSH target for our MCP VPS.
GAZE_SSH_HOST=linuxuser@45.76.219.241

# Command executed on our MCP VPS. Keep gaze realtime data in its own JSON store;
# do not point this at /home/linuxuser/.mcp/memory.jsonl.
GAZE_REMOTE_COMMAND=GAZE_STORE_PATH=/home/linuxuser/search_tool/gaze_realtime.json GAZE_TTL_SECONDS=21600 python3 /home/linuxuser/search_tool/gaze_push_caption.py

# Extra comma-separated words to remove from OCR/caption text before upload.
GAZE_BOOKMARK_KEYWORDS=

# Server-side TTL. For VPS use, set this on the VPS or prefix GAZE_REMOTE_COMMAND with it.
# 0 disables TTL cleanup.
GAZE_TTL_SECONDS=21600
