# Copy to .env and fill the values you actually want to use.

# Required only when --caption-provider glm is enabled.
GLM_API_KEY=

# SSH alias from ~/.ssh/config, for example: migratorybird
GAZE_SSH_HOST=

# Command executed on the VPS. Keep this pointed at the installed push_caption.py.
GAZE_REMOTE_COMMAND=python3 /root/mcp-memory-server/push_caption.py

# Extra comma-separated words to remove from OCR/caption text before upload.
GAZE_BOOKMARK_KEYWORDS=
